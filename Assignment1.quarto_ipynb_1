      "source": [
        "# Clean column names\n",
        "sensor_locations = sensor_locations.rename(columns={\n",
        "    \"Address\": \"Location\",\n",
        "    \"Latitude\": \"lat\",\n",
        "    \"Longitude\": \"lon\"\n",
        "})\n",
        "\n",
        "# Fix the typo so it matches your cleaned ped_long names\n",
        "sensor_locations[\"Location\"] = sensor_locations[\"Location\"].replace({\n",
        "    \"59 High Stret\": \"59 High Street\"\n",
        "})\n",
        "\n",
        "sensor_locations.head()\n",
        "\n",
        "# Drop rows with missing lat/lon \n",
        "sensor_clean = sensor_locations.dropna(subset=[\"lat\", \"lon\"]).copy()\n",
        "\n",
        "# Convert to GeoDataFrame \n",
        "sensors_gdf = gpd.GeoDataFrame(\n",
        "    sensor_clean,\n",
        "    geometry=gpd.points_from_xy(sensor_clean[\"lon\"], sensor_clean[\"lat\"]),\n",
        "    crs=\"EPSG:4326\"\n",
        ")\n",
        "\n",
        "sensors_gdf.head()\n",
        "sensor_locations.describe()\n",
        "\n",
        "#Convert to wide format\n",
        "sensor_year_wide = (\n",
        "    ped_long\n",
        "    .groupby([\"Location\", \"year\"])[\"Count\"]\n",
        "    .sum()\n",
        "    .reset_index()\n",
        "    .pivot(index=\"Location\", columns=\"year\", values=\"Count\")\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "# Convert year columns to STRINGS (critical fix)\n",
        "sensor_year_wide = sensor_year_wide.rename(columns={\n",
        "    2020: \"2020\",\n",
        "    2021: \"2021\",\n",
        "    2022: \"2022\",\n",
        "    2023: \"2023\",\n",
        "    2024: \"2024\"\n",
        "})\n",
        "\n",
        "sensor_year_wide = compute_recovery(sensor_year_wide)\n",
        "# Merge into sensor GeoDataFrame\n",
        "sensors_recovery = sensors_gdf.merge(\n",
        "    sensor_year_wide[[\"Location\", \"2020\", \"2024\", \"pct_recovery\"]],\n",
        "    on=\"Location\",\n",
        "    how=\"left\"\n",
        ").dropna(subset=[\"pct_recovery\"])\n",
        "\n",
        "# Spatial join: assign each sensor to an SA2\n",
        "joined_sa2 = gpd.sjoin(\n",
        "    sensors_gdf,\n",
        "    sa2_2023_4326,\n",
        "    how=\"left\",\n",
        "    predicate=\"within\"\n",
        ")\n",
        "\n",
        "# Merge ped_long with SA2 info\n",
        "ped_sa2 = ped_long.merge(\n",
        "    joined_sa2[[\"Location\", \"SA22023_V1_00_NAME\"]],\n",
        "    on=\"Location\",\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "# Total footfall per SA2 per year\n",
        "sa2_year = (\n",
        "    ped_sa2\n",
        "    .groupby([\"SA22023_V1_00_NAME\", \"year\"])[\"Count\"]\n",
        "    .sum()\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "# Pivot to wide format\n",
        "sa2_year_wide = sa2_year.pivot(\n",
        "    index=\"SA22023_V1_00_NAME\",\n",
        "    columns=\"year\",\n",
        "    values=\"Count\"\n",
        ").reset_index()\n",
        "\n",
        "# Convert year columns to STRINGS (critical fix)\n",
        "sa2_year_wide = sa2_year_wide.rename(columns={\n",
        "    2020: \"2020\",\n",
        "    2021: \"2021\",\n",
        "    2022: \"2022\",\n",
        "    2023: \"2023\",\n",
        "    2024: \"2024\"\n",
        "})\n",
        "\n",
        "# Compute SA2 recovery\n",
        "sa2_year_wide = compute_recovery(sa2_year_wide)\n",
        "\n",
        "# Merge ALL year totals + recovery into SA2 polygons\n",
        "sa2_recovery = sa2_2023_4326.merge(\n",
        "    sa2_year_wide[\n",
        "        [\"SA22023_V1_00_NAME\", \"2020\", \"2021\", \"2022\", \"2023\", \"2024\", \"pct_recovery\"]\n",
        "    ],\n",
        "    on=\"SA22023_V1_00_NAME\",\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "# Remove SA2s with no recovery value\n",
        "sa2_recovery_clean = sa2_recovery.dropna(subset=[\"pct_recovery\"]).copy()\n",
        "\n",
        "m = folium.Map(\n",
        "    location=[sensors_gdf[\"lat\"].mean(), sensors_gdf[\"lon\"].mean()],\n",
        "    zoom_start=15,\n",
        "    tiles=\"CartoDB Positron\"\n",
        ")\n",
        "\n",
        "colormap = cm.linear.PuOr_11.scale(\n",
        "    sa2_recovery_clean[\"pct_recovery\"].min(),\n",
        "    sa2_recovery_clean[\"pct_recovery\"].max()\n",
        ")\n",
        "\n",
        "colormap.caption = \"SA2 Footfall Recovery (2024 vs 2020)\"\n",
        "colormap.add_to(m)\n",
        "\n",
        "tooltip = folium.GeoJsonTooltip(\n",
        "    fields=[\"SA22023_V1_00_NAME\", \"2020\", \"2021\", \"2022\", \"2023\", \"2024\", \"pct_recovery\"],\n",
        "    aliases=[\"SA2:\", \"2020:\", \"2021:\", \"2022:\", \"2023:\", \"2024:\", \"Recovery (%):\"],\n",
        "    localize=True\n",
        ")\n",
        "\n",
        "style_fn = lambda feature: {\n",
        "    \"fillColor\": colormap(float(feature[\"properties\"][\"pct_recovery\"])),\n",
        "    \"color\": \"#222222\",      # darker outline for visibility\n",
        "    \"weight\": 0.4,           # thinner borders\n",
        "    \"fillOpacity\": 0.85,     # stronger fill\n",
        "}\n",
        "\n",
        "highlight_fn = lambda feature: {\n",
        "    \"fillColor\": colormap(float(feature[\"properties\"][\"pct_recovery\"])),\n",
        "    \"color\": \"black\",\n",
        "    \"weight\": 2,\n",
        "    \"fillOpacity\": 0.95,\n",
        "}\n",
        "\n",
        "folium.GeoJson(\n",
        "    sa2_recovery_clean,\n",
        "    style_function=style_fn,\n",
        "    highlight_function=highlight_fn,\n",
        "    tooltip=tooltip\n",
        ").add_to(m)\n",
        "\n",
        "for _, row in sensors_recovery.iterrows():\n",
        "    folium.CircleMarker(\n",
        "        location=[row.lat, row.lon],\n",
        "        radius=6,\n",
        "        fill=True,\n",
        "        fill_color=\"black\",\n",
        "        color=\"white\",\n",
        "        weight=1,\n",
        "        tooltip=(\n",
        "            f\"<b>{row['Location']}</b><br>\"\n",
        "            f\"2020 total: {row['2020']:,}<br>\"\n",
        "            f\"2024 total: {row['2024']:,}<br>\"\n",
        "            f\"Recovery: {row['pct_recovery']:.1f}%\"\n",
        "        )\n",
        "    ).add_to(m)"
