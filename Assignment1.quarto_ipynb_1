      "source": [
        "Imported the API from STATS NZ using a API Key and reprojected CRS from 2193 to 4326 to ensure that the SA2 blocks will work with the Geodata downloaded from Heart of the City sensor data. "
      ],
      "id": "eb368322"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: True\n",
        "\n",
        "#=========================\n",
        "#     API INTEGRATION \n",
        "#=========================\n",
        "\n",
        "from config import API_KEY \n",
        "\n",
        "LAYER_ID = 111227   # SA2 2023 layer\n",
        "BASE_URL = \"https://datafinder.stats.govt.nz/services/api/v1.x\"\n",
        "\n",
        "HEADERS = {\n",
        "    \"Authorization\": f\"key {API_KEY}\",\n",
        "    \"Content-Type\": \"application/json\",\n",
        "}\n",
        "\n",
        "payload = {\n",
        "    \"crs\": \"EPSG:2193\",   # Stats NZ default (NZTM)\n",
        "    \"formats\": {\"vector\": \"application/x-ogc-gpkg\"},\n",
        "    \"items\": [{\"item\": f\"{BASE_URL}/layers/{LAYER_ID}/\"}],\n",
        "}\n",
        "\n",
        "response = requests.post(f\"{BASE_URL}/exports/\", json=payload, headers=HEADERS)\n",
        "response.raise_for_status()\n",
        "\n",
        "export_data = response.json()\n",
        "export_url = export_data[\"url\"]\n",
        "\n",
        "print(\"Export job created:\", export_url)\n",
        "print(\"Initial state:\", export_data[\"state\"])\n",
        "\n",
        "while True:\n",
        "    status = requests.get(export_url, headers=HEADERS).json()\n",
        "    state = status[\"state\"]\n",
        "    print(\"Export state:\", state)\n",
        "\n",
        "    if state == \"complete\":\n",
        "        download_url = status[\"download_url\"]\n",
        "        break\n",
        "    elif state == \"failed\":\n",
        "        raise RuntimeError(\"Export failed.\")\n",
        "\n",
        "    time.sleep(2)\n",
        "\n",
        "zip_path = \"sa2_2023.zip\"\n",
        "dl = requests.get(download_url, headers=HEADERS, stream=True)\n",
        "dl.raise_for_status()\n",
        "\n",
        "with open(zip_path, \"wb\") as f:\n",
        "    for chunk in dl.iter_content(chunk_size=8192):\n",
        "        f.write(chunk)\n",
        "\n",
        "print(\"ZIP downloaded:\", zip_path)\n",
        "\n",
        "extract_folder = \"sa2_2023/\"\n",
        "with zipfile.ZipFile(zip_path) as zf:\n",
        "    gpkg_name = [n for n in zf.namelist() if n.endswith(\".gpkg\")][0]\n",
        "    zf.extractall(extract_folder)\n",
        "\n",
        "print(\"Extracted:\", gpkg_name)\n",
        "\n",
        "sa2_2023 = gpd.read_file(f\"{extract_folder}{gpkg_name}\")\n",
        "print(\"Original CRS:\", sa2_2023.crs)\n",
        "print(sa2_2023.shape)\n",
        "\n",
        "sa2_2023_4326 = sa2_2023.to_crs(\"EPSG:4326\")\n",
        "print(\"Reprojected CRS:\", sa2_2023_4326.crs)\n",
        "\n",
        "output_path = \"sa2_2023_4326.gpkg\"\n",
        "sa2_2023_4326.to_file(output_path, driver=\"GPKG\")\n",
        "\n",
        "print(\"Saved:\", output_path)"
      ],
      "id": "36298c22",
      "execution_count": null,
      "outputs": []
